# ==========================================
# Query Analyzer - Configuración de Entorno
# ==========================================

# ==========================================
# SQL Databases
# ==========================================

# PostgreSQL
DB_POSTGRES_USER=qa
DB_POSTGRES_PASSWORD=QAnalyze
DB_POSTGRES_NAME=query_analyzer
DB_POSTGRES_PORT=5432

# MySQL
DB_MYSQL_USER=qa
DB_MYSQL_PASSWORD=QAnalyze
DB_MYSQL_NAME=query_analyzer
DB_MYSQL_PORT=3306

# SQLite
DB_SQLITE_PATH=query_analyzer.db
DB_SQLITE_NAME=query_analyzer

# ==========================================
# NoSQL / Cache Databases
# ==========================================

# MongoDB
DB_MONGODB_USER=admin
DB_MONGODB_PASSWORD=mongodb123
DB_MONGODB_NAME=query_analyzer
DB_MONGODB_PORT=27017

# Redis
DB_REDIS_PORT=6379

# ==========================================
# Time-Series & Graph Databases
# ==========================================

# InfluxDB
DB_INFLUXDB_USER=admin
DB_INFLUXDB_PASSWORD=influxdb123
DB_INFLUXDB_NAME=query_analyzer
DB_INFLUXDB_PORT=8086

# Neo4j
DB_NEO4J_USER=neo4j
DB_NEO4J_PASSWORD=neo4j123
DB_NEO4J_BOLT_PORT=7687
DB_NEO4J_HTTP_PORT=7474

# CockroachDB
DB_COCKROACH_PORT=26257
DB_COCKROACH_HTTP_PORT=8080

# YugabyteDB
# Note: YugabyteDB uses hardcoded credentials (yugabyte/yugabyte)
# Environment variables below are for reference only - they cannot be changed in the container
# The entrypoint script creates the query_analyzer database on initialization
DB_YUGABYTE_USER=yugabyte
DB_YUGABYTE_PASSWORD=yugabyte
DB_YUGABYTE_PORT=5433
DB_YUGABYTE_UI_PORT=7000

# ==========================================
# Configuración de la Aplicación
# ==========================================
LOG_LEVEL=INFO
DEBUG=false
